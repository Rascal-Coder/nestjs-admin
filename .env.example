# 应用（宿主机跑 Nest 时，数据库/Redis 主机用 127.0.0.1，端口与 docker-compose 映射一致）
NODE_ENV=development
PORT=8000
API_PREFIX=api

# MySQL（Prisma CLI 与 PrismaService 共用）
DATABASE_URL=mysql://root:dev_root_password@127.0.0.1:3306/nestjs_admin

# Redis
REDIS_URL=redis://127.0.0.1:6379

# MinIO（S3 兼容）
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=nestjs-admin
MINIO_REGION=us-east-1

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Casbin 模型文件（相对项目根）
CASBIN_MODEL_PATH=src/casbin/model.conf

# 种子（可选，pnpm prisma:seed）
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin12345!
